# Power Platform / pac CLI build artifacts — the *.pa.yaml and *.yml source is
# the source of truth; these are generated and should not be committed.

# Built solution packages
out/
*.zip

# Binary canvas app packages — regenerated by `pac solution pack` from *.pa.yaml
*.msapp

# Power Apps Studio-only cache (not stable source)
**/EditorState/
*.editorstate.json

# pac CLI / solution project scratch
bin/
obj/
.pac/

# Auth is machine-local — never commit
*.pac-auth
